# Copy this file to .env.local for local development, or set these as
# environment variables in your hosting provider (Vercel → Project → Settings
# → Environment Variables). Never commit .env.local or paste real values into
# a chat — see SETUP.md and Doc 2's "Don't paste secrets into Claude."

# --- Required -----------------------------------------------------------

# Airtable, Builder Hub -> Personal Access Tokens. Scopes: data.records:read,
# data.records:write, for the base you create per SETUP.md Step 1.
AIRTABLE_TOKEN=
# The base ID (starts with "app…"), from the Airtable base's API docs page.
AIRTABLE_BASE_ID=

# console.anthropic.com -> API Keys. Powers every AI-drafted email.
ANTHROPIC_API_KEY=

# The password used to sign in to this dashboard (single shared password —
# see SETUP.md for why, and how to upgrade this later).
DASHBOARD_PASSWORD=
# Any long random string, used to sign the login session cookie.
# Generate one with: openssl rand -base64 32
SESSION_SECRET=

# --- Optional -------------------------------------------------------------

# Shared secret your scheduler sends as "Authorization: Bearer <value>" when
# it calls POST /api/cron/scan. Required only if you wire up the twice-weekly
# scheduled sync+scan (recommended for production).
CRON_SECRET=

# Email sender — set ONE of these pairs, or leave both blank to hold every
# approved draft for manual copy-paste (the "manual" sender fallback).
RESEND_API_KEY=
RESEND_FROM_ADDRESS=

INSTANTLY_API_KEY=
